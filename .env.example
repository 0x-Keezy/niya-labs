# ==============================================================================
#  Niya Labs — environment variables
# ==============================================================================
#  Copy this file to `.env.local` and fill in the values you actually need.
#  `.env.local` is gitignored — it will never be committed.
#
#  ⚠️  NEXT_PUBLIC_* WARNING  ⚠️
#  Variables prefixed with NEXT_PUBLIC_* are embedded in the browser bundle
#  at build time. They are SAFE for local dev and demo only. In production,
#  prefer the non-prefixed server-only equivalents (DGRID_API_KEY,
#  MORALIS_API_KEY, BSCSCAN_API_KEY, etc.) which the API routes under
#  /api/nyla-tools/* and /api/companion/* use internally — those never reach
#  the client.
#
#  The legacy NEXT_PUBLIC_*_API_KEY variables are kept so that the older
#  browser-side chat/TTS/Twitter adapters still work for contributors running
#  locally. If you deploy publicly, remove them and route everything through
#  the server API.
#
#  Legend:
#    [REQUIRED]  must be set for the feature to work
#    [OPTIONAL]  feature is off or falls back when unset
#    [SERVER]    server-only, never in the browser bundle (safe)
#    [PUBLIC]    embedded in browser bundle — see warning above
# ==============================================================================

# Copy this file to .env.local and fill in your values

# ==========================================
# CORE APPLICATION SETTINGS
# ==========================================

# Base URL for development (leave empty for production)
NEXT_PUBLIC_DEVELOPMENT_BASE_URL=

# Admin authentication password (required for admin features).
# Use >= 16 random chars. Generate: openssl rand -base64 24
ADMIN_PASSWORD=

# Opaque secret used to sign httpOnly admin session cookies.
# Never share, never commit. Generate: openssl rand -base64 32
SESSION_SECRET=

# Comma-separated CORS allowlist. Leave blank for default (localhost + niyaagent.com).
NIYA_CORS_ALLOWED_ORIGINS=

# Autonomous trading kill switch. Defaults to ON (blocks agent-initiated swaps).
# Set to "off" ONLY if you have reviewed the risks in SECURITY.md and explicitly
# want the ElizaOS agent to execute trades without admin approval.
AUTONOMY_TRADING_KILL_SWITCH=on

# Base URL used for canonical links and OG meta. Default: https://niyaagent.com
NEXT_PUBLIC_BASE_URL=https://niyaagent.com

# Enable Google Analytics. Defaults OFF — set "true" only with a cookie consent banner in place.
NEXT_PUBLIC_GA_ENABLED=

# ==========================================
# LLM PROVIDER SETTINGS (Choose one or more)
# ==========================================

# DGrid AI Gateway (PREFERRED — unified access to 200+ LLMs)
# DGrid is an OpenAI-compatible Web3-native gateway. When DGRID_API_KEY is set,
# the Nyla Tools API (/api/nyla-tools/ask, /narrate) AND the VTuber companion
# chat (/api/companion/chat) both route through DGrid; the legacy xAI vars
# below are ignored. Get a key at https://dgrid.ai.
# Docs: https://docs.dgrid.ai/AI-Gateway-Integrations
# Models: https://dgrid.ai/models (format: provider/model-name)
# Server-only — never exposed to the browser. The companion chat is proxied
# through a Next.js API route so the key stays out of the client bundle.
DGRID_API_KEY=
DGRID_MODEL=openai/gpt-4o-mini

# xAI / Grok (Legacy fallback — used when DGRID_API_KEY is unset)
# RECOMMENDED: server-only (not exposed to the browser bundle). Used by the
# Nyla Tools API (/api/nyla-tools/ask, /narrate) ONLY when DGRID_API_KEY is
# not configured. If both are set, the server-only variable wins.
XAI_API_KEY=
XAI_URL=https://api.x.ai/v1
XAI_MODEL=grok-3-mini
# LEGACY (exposed to the client bundle). Only set these if you still run the
# browser-side chat adapters that call xAI directly.
NEXT_PUBLIC_XAI_API_KEY=
NEXT_PUBLIC_XAI_URL=https://api.x.ai/v1
NEXT_PUBLIC_XAI_MODEL=grok-3-mini

# OpenAI (Legacy fallback)
NEXT_PUBLIC_OPENAI_APIKEY=
NEXT_PUBLIC_OPENAI_URL=https://api.openai.com/v1
NEXT_PUBLIC_OPENAI_MODEL=gpt-4o

# OpenRouter
NEXT_PUBLIC_OPENROUTER_APIKEY=
NEXT_PUBLIC_OPENROUTER_URL=https://openrouter.ai/api/v1
NEXT_PUBLIC_OPENROUTER_MODEL=openai/gpt-4o

# DeepSeek (Reasoning Engine)
NEXT_PUBLIC_DEEPSEEK_API_KEY=
NEXT_PUBLIC_DEEPSEEK_URL=https://api.deepseek.com/v1
NEXT_PUBLIC_DEEPSEEK_MODEL=deepseek-reasoner

# ==========================================
# VOICE SETTINGS (TTS & STT)
# ==========================================

# ElevenLabs TTS
NEXT_PUBLIC_ELEVENLABS_APIKEY=
NEXT_PUBLIC_ELEVENLABS_VOICEID=

# OpenAI TTS
NEXT_PUBLIC_OPENAI_TTS_APIKEY=

# OpenAI Whisper STT
NEXT_PUBLIC_OPENAI_WHISPER_APIKEY=
NEXT_PUBLIC_OPENAI_WHISPER_URL=https://api.openai.com/v1

# ==========================================
# VISION / IMAGE UNDERSTANDING
# ==========================================

NEXT_PUBLIC_VISION_OPENAI_APIKEY=
NEXT_PUBLIC_VISION_OPENAI_URL=https://api.x.ai/v1
NEXT_PUBLIC_VISION_OPENAI_MODEL=grok-2-vision-latest

# ==========================================
# SOCIAL MEDIA INTEGRATIONS
# ==========================================

# Twitter/X API (@NiyaAgent)
NEXT_PUBLIC_X_API_KEY=
NEXT_PUBLIC_X_API_SECRET=
NEXT_PUBLIC_X_ACCESS_TOKEN=
NEXT_PUBLIC_X_ACCESS_SECRET=
NEXT_PUBLIC_X_BEARER_TOKEN=

# Telegram Bot
NEXT_PUBLIC_TELEGRAM_BOT_TOKEN=
NEXT_PUBLIC_TELEGRAM_CHAT_ID=

# ==========================================
# BLOCKCHAIN / SOLANA
# ==========================================

# Helius RPC
NEXT_PUBLIC_HELIUS_API_KEY=

# Jupiter API
JUPITER_API_KEY=

# ==========================================
# OPTIONAL SERVICES
# ==========================================

# Coqui TTS (Optional)
NEXT_PUBLIC_COQUI_APIKEY=

# Supabase (Optional - for cloud features)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
