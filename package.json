{
  "name": "niya-labs",
  "version": "0.1.0",
  "private": true,
  "description": "One AI VTuber (Niya) + one BNB-Chain token analyzer (Niya Tools), under one brand. Four.meme AI Sprint × DGrid Gateway. Read-only, no signatures.",
  "homepage": "https://niyaagent.com",
